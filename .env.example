# Server
CRAWLBRIEF_PORT=3001
CRAWLBRIEF_BASE_URL=https://crawlbrief.yourdomain.com

# Database (use host.docker.internal to connect from Docker to host's PostgreSQL on port 5433)
CRAWLBRIEF_DATABASE_URL=postgresql://crawlbrief:your-secure-password@host.docker.internal:5433/crawlbrief

# Firecrawl Gateway
CRAWLBRIEF_GATEWAY_URL=http://localhost:3000
CRAWLBRIEF_GATEWAY_TOKEN=your-gateway-token-here

# LLM Provider
CRAWLBRIEF_LLM_PROVIDER=openai
CRAWLBRIEF_OPENAI_MODEL=gpt-4o-mini
CRAWLBRIEF_ANTHROPIC_MODEL=claude-3-haiku-20240307

# Cloudflare AI Gateway (BYOK mode - API keys stored in Cloudflare)
# 1. Create gateway: https://dash.cloudflare.com/?to=/:account/ai/ai-gateway
# 2. Add provider keys: Gateway > Provider Keys > Add (store OpenAI/Anthropic keys)
# 3. Enable auth: Gateway > Settings > Authenticated Gateway > Generate Token
CRAWLBRIEF_CF_AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/your-account-id/your-gateway-name
CRAWLBRIEF_CF_AI_GATEWAY_TOKEN=your-cf-aig-token
CRAWLBRIEF_CF_AI_GATEWAY_USE_BYOK=true

# Alternative: Direct API keys (set USE_BYOK=false to use these instead)
# CRAWLBRIEF_OPENAI_API_KEY=sk-your-openai-key
# CRAWLBRIEF_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# CRAWLBRIEF_CF_AI_GATEWAY_USE_BYOK=false

# Slack
CRAWLBRIEF_SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
CRAWLBRIEF_SLACK_CHANNEL_ID=C0123456789

# API Authentication (for manual trigger endpoint)
CRAWLBRIEF_API_TOKEN=your-api-token-here

# Webhook Security (optional but recommended - min 16 chars)
CRAWLBRIEF_WEBHOOK_SECRET=your-webhook-secret-here

# Logging
CRAWLBRIEF_LOG_LEVEL=info

# Timezone for cron schedules (IANA timezone name)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
CRAWLBRIEF_TIMEZONE=Pacific/Auckland
